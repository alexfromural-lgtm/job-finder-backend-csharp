PORT=5002
ASPNETCORE_ENVIRONMENT=Development

# Database — same connection details as Node.js stack but using C# container names
DB_HOST=job-finder-db-csharp
DB_NAME=job-finder
DB_USER=job_finder_user
DB_PASS=secure_password_123
DATABASE_URL=Host=job-finder-db-csharp;Port=5432;Database=job_finder;Username=job_finder_user;Password=secure_password_123

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# JWT secrets (generate strong random values for production)
ACCESS_TOKEN_SECRET=change_me_access_secret_min_16_chars
ACCESS_TOKEN_EXPIRES_IN_MINUTES=15
REFRESH_TOKEN_SECRET=change_me_refresh_secret_min_16_chars
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# Redis — same service name as the Node.js stack but using C# container names
REDIS_URL=job-finder-redis-csharp:6379
QUEUE_CONCURRENCY=5

# CORS
CORS_ORIGIN=http://localhost:3000
